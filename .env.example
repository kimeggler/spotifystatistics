# Vite Environment Variables
# Copy this to .env.local and fill in your actual values

# Spotify API Configuration
VITE_CLIENT_ID=your_spotify_client_id_here

# Optional: Override redirect URI (useful for custom deployments)
# Leave empty for automatic detection
# Local: http://127.0.0.1:3000/callback (default for dev)
# Production: Will use window.location.origin/callback
# VITE_REDIRECT_URI=
